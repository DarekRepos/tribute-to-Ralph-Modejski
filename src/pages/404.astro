---
import Layout from "../layouts/Page.astro";
import Container from "../components/core/Container.astro";
import TextCardSection from "../components/section/TextCardSection.astro";
import Button from "../components/buttons/Button.astro";
---

<Layout>
    <Container>
        <TextCardSection>
            <div class="section-container">
                <h1 data-i18n="notFound.title">404</h1>
                <h2 data-i18n="notFound.heading">Page Not Found 👀</h2>
                <div class="cta-buttons__container">
                    <Button href="/" data-i18n="notFound.returnHome"> Return Home </Button>
                </div>
            </div>
        </TextCardSection>
    </Container>
    <script>
        import { initTranslations } from "../utils/i18n-client";
        initTranslations();
    </script>
</Layout>

<style style="scss">
    .section-container{
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 3rem;
    
    }
    .cta-buttons__container {
        display: flex;
        flex-wrap: wrap;
        &:global(a) {
            margin-right: 1rem;
            margin-bottom: 1rem;
        }
        > a {
            margin-right: 1rem;
            margin-bottom: 1rem;
        }
    }
    .cta-buttons__container .code-buttons__container {
        margin: 1rem auto;
        display: flex;
        flex-wrap: wrap;
    }
</style>
